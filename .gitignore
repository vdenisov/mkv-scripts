# IDE / build artifacts
.idea/
*.iml
# Root-anchored: an unanchored "out/" also matches the src/.../mkvtool/out/ package dir.
/out/
.claude/

# Gradle / Kotlin build (the wrapper itself — gradlew*, gradle/wrapper/ — is tracked)
build/
.gradle/
.kotlin/

# Secrets and personal data
apikey.txt
episodes.txt
episodes.txt.bak
episodes.yaml
http-client.private.env.json

# Local docs are working notes — keep only CLAUDE.md and README.md tracked.
# (docs/reference.md is already tracked, so this does not untrack it.)
*.md
!CLAUDE.md
!README.md

# Test artifacts
work/
